-- Logic
local holding = nil
local duplicateClone = nil
local loading = false


local function makeIndependentClone(tool)

	local clone = tool:Clone()
	clone.Name = tool.Name
	clone:SetAttribute("FakeClone",true)

	return clone

end



player.Character.ChildAdded:Connect(function(child)

	if child:IsA("Tool") then
		holding = child
	end

end)



player.Character.ChildRemoved:Connect(function(child)

	if child == holding then
		holding = nil
	end

end)



DuplicateButton.MouseButton1Click:Connect(function()

	if loading or not holding then return end

	loading = true
	LoadingLabel.Text = "0%"


	spawn(function()

		local totalTime = math.random(15,20)
		local stepTime = totalTime / 100


		for i = 1,100 do

			LoadingLabel.Text = i.."%"
			wait(stepTime)

		end


		duplicateClone = makeIndependentClone(holding)

		duplicateClone.Parent = player.Backpack


		LoadingLabel.Text = "Done!"

		wait(0.5)

		LoadingLabel.Text = ""

		loading = false

	end)

end)



-- Drag System
local dragToggle
local dragInput
local dragStart
local startPos


local function update(input)

	local delta = input.Position - dragStart

	Frame.Position =
	UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)

end



Frame.InputBegan:Connect(function(input)

	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then

		dragToggle = true
		dragStart = input.Position
		startPos = Frame.Position


		input.Changed:Connect(function()

			if input.UserInputState == Enum.UserInputState.End then

				dragToggle = false

			end

		end)

	end

end)



Frame.InputChanged:Connect(function(input)

	if input.UserInputType == Enum.UserInputType.MouseMovement
	or input.UserInputType == Enum.UserInputType.Touch then

		dragInput = input

	end

end)



UserInputService.InputChanged:Connect(function(input)

	if input == dragInput and dragToggle then

		update(input)

	end

end)
